# Cloudflare R2 Configuration
# Find your Account ID in the Cloudflare Dashboard overview
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# R2 Access Key ID (created in R2 > Manage R2 API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 Secret Access Key (created in R2 > Manage R2 API Tokens)
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# The name of your R2 bucket
CLOUDFLARE_BUCKET_NAME=your_bucket_name_here

# Optional: Custom domain for public access (e.g., https://cdn.example.com)
# If not set, you may need to construct the URL using the account ID and bucket name
CLOUDFLARE_R2_PUBLIC_URL=